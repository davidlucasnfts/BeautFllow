# BeautyFlow — Environment Variables Template
# Copiar para .env e preencher com valores reais
# NUNCA commitar .env com valores reais

# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing) — min 32 chars

# ── Database (PostgreSQL / Supabase) ───────────────────────────
DATABASE_URL=             # PostgreSQL connection string (postgresql://user:pass@host:port/db?sslmode=require)

# ── Frontend (exposed to browser via Vite) ──────────────────────
# ATENCAO: NUNCA prefixe secrets com VITE_ — elas ficam expostas no bundle do cliente
VITE_KIMI_AUTH_URL=       # Kimi OAuth server URL (e.g. https://auth.kimi.com)
VITE_APP_ID=              # OAuth application ID (publico, OK expor no frontend)

# ── Backend (Auth) ─────────────────────────────────────────────
KIMI_AUTH_URL=            # Kimi OAuth server URL (backend)
KIMI_OPEN_URL=            # Kimi Open Platform URL (e.g. https://open.kimi.com)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login

# ── Sentry (Error Tracking) ─────────────────────────────────────
# Opcional — só em produção
SENTRY_DSN=               # Backend DSN (ex: https://xxx@yyy.ingest.sentry.io/zzz)
VITE_SENTRY_DSN=          # Frontend DSN (mesmo valor, exposto no bundle)
